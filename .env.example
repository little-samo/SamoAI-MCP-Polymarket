# Server
PORT=11188

# Polymarket Authentication (optional - omit for read-only mode)
# Only POLYMARKET_PRIVATE_KEY is needed for trading.
# API credentials are auto-derived from the private key on startup.
POLYMARKET_PRIVATE_KEY=

# Proxy wallet address shown on https://polymarket.com/settings
# Required when using GNOSIS_SAFE signature type (default).
POLYMARKET_FUNDER_ADDRESS=

# Signature type: 0 = EOA, 1 = POLY_PROXY, 2 = GNOSIS_SAFE (default)
# POLYMARKET_SIGNATURE_TYPE=2
