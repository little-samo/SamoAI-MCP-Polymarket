# Server
PORT=11188

# Polymarket Authentication (optional - omit for read-only mode)
# Only POLYMARKET_PRIVATE_KEY is needed for trading.
# API credentials are auto-derived from the private key on startup.
POLYMARKET_PRIVATE_KEY=

# Signature type: 0 = EOA, 1 = POLY_PROXY, 2 = GNOSIS_SAFE (default)
# POLYMARKET_SIGNATURE_TYPE=2

# Funder address: your proxy wallet address shown at polymarket.com/settings
# Required for POLY_PROXY and GNOSIS_SAFE signature types
# POLYMARKET_FUNDER_ADDRESS=0x...

# Polygon RPC URL priority:
# 1) POLYGON_RPC_URL or https://polygon.drpc.org
# 2) https://rpc-mainnet.matic.quiknode.pro
# 3) https://polygon-rpc.com
# POLYGON_RPC_URL=https://polygon.drpc.org

# Builder Relayer (gasless claim — polymarket.com/settings?tab=builder)
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# Optional override for the builder relayer endpoint
# POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com/
