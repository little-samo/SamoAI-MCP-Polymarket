# Server
PORT=11188

# Polymarket Authentication (optional - omit for read-only mode)
# Only POLYMARKET_PRIVATE_KEY is needed for trading.
# API credentials are auto-derived from the private key on startup.
POLYMARKET_PRIVATE_KEY=

# Signature type: 0 = EOA, 1 = POLY_PROXY, 2 = GNOSIS_SAFE (default)
# POLYMARKET_SIGNATURE_TYPE=2

# Funder address: your proxy wallet address shown at polymarket.com/settings
# Required for POLY_PROXY and GNOSIS_SAFE signature types
# POLYMARKET_FUNDER_ADDRESS=0x...

# Polygon RPC URL (default: https://polygon-rpc.com)
# POLYGON_RPC_URL=https://polygon-rpc.com
